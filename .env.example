# Bu dosya repo'da; .env değil (.gitignore'da).
# Yeni geliştirici şu komutu çalıştırır: cp .env.example .env
# Sonra .env'i kendi değerleriyle doldurur.

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://gtfs_user:gtfs_pass@localhost:5433/gtfs_db

# ─── API Security ─────────────────────────────────────────
# Admin endpoint'leri (örn POST /import/) için API key'ler.
# Birden fazla key virgülle ayrılır (örn farklı kullanıcı/sistem için).
# Production'da random 32+ karakter kullan, basit string asla.
ADMIN_API_KEYS=changeme-admin-secret-key

# ─── Rate Limit ───────────────────────────────────────────
# IP başına dakikalık istek limiti. 0 = devre dışı.
RATE_LIMIT_PER_MINUTE=60

# ─── CORS ─────────────────────────────────────────────────
# Frontend hangi origin'lerden çağrı atabilir?
# Virgülle ayrılır. "*" = tüm origin'ler (sadece geliştirme için!).
# Production: https://frontend.example.com gibi spesifik domain.
CORS_ORIGINS=*
